/*
  Подключение к Arduino Mega Pro через конвертер уровней:
  Raspberry Pi 4 (Пин 14 TX) -> [Конвертер уровней] -> Arduino Mega Pro (Пин 19 RX1)
  Общая земля (GND) обеих плат должна быть соединена!
*/

void setup() {
  // Инициализируем стандартный USB-порт для отладки на ПК
  Serial.begin(9600);   
  
  // Инициализируем аппаратный порт Serial1 для связи с Raspberry Pi 4
  Serial1.begin(115200);  
  
  Serial.println("=============================================");
  Serial.println("=== Arduino Mega Pro готова к приему угла ===");
  Serial.println("=============================================");
}

void loop() {
  // Проверяем, пришли ли байты от Raspberry Pi в порт Serial1
  if (Serial1.available() > 0) {
    
    // Читаем первый доступный байт — ищем наш маркер начала пакета
    char startChar = Serial1.read();
    
    if (startChar == 'A') {
      // Считываем идущее следом число типа int (до любого нечислового символа)
      int angle = Serial1.parseInt(); 
      
      // Читаем следующий за числом байт — это должен быть символ '\n'
      char endChar = Serial1.read();
      
      if (endChar == '\n') {
        // --- ДАННЫЕ УСПЕШНО И БЕЗ ОШИБОК ПРИНЯТЫ ---
        
        // Выводим принятый угол на компьютер для контроля
        Serial.print("Успешно получен угол от RPi: ");
        Serial.println(angle);
        
        // ========================================================
        // МЕСТО ДЛЯ ВАШЕГО КОДА:
        // Используйте переменную 'angle' (0-360) для управления.
        // Пример: servo.write(angle); или расчет движения моторов
        // ========================================================
        
      } else {
        // Если в конце пакета не перевод строки, значит данные повреждены
        Serial.println("[ERROR] Ошибка структуры пакета: пропущен '\\n'");
      }
    }
  }
}